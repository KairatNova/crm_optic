POSTGRES_DB=crm_optic
POSTGRES_USER=crm_optic
POSTGRES_PASSWORD=crm_optic
POSTGRES_HOST=localhost
POSTGRES_PORT=5432


BACKEND_PORT=8000

DATABASE_URL=postgresql+psycopg://crm_optic:crm_optic@localhost:5432/crm_optic

# Auth (owner + admins)
JWT_SECRET=change-me-to-long-random-string
JWT_EXPIRE_MINUTES=43200
VERIFICATION_CODE_TTL_MINUTES=10
START_TOKEN_TTL_MINUTES=10
VERIFICATION_MAX_ATTEMPTS=5
TELEGRAM_BOT_USERNAME=your_bot_username
TELEGRAM_BOT_WEBHOOK_SECRET=change-me-bot-secret

# Legacy (optional, old flow; can stay empty)
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOOTSTRAP_OWNER_TELEGRAM_ID=

# CORS (frontend origins, comma-separated)
CORS_ORIGINS=http://localhost:3000
